EESchema Schematic File Version 4
LIBS:Symbol.lib
EELAYER 30 0
EELAYER END
$Descr A4 11693 8268
encoding utf-8
Sheet 1 1
Title "E-Ink Voice Agent - Waveshare ESP32-C6-ePaper-1.54"
Date "2026-06-30"
Rev "1.0"
Comp "Custom additions to Waveshare ESP32-C6-ePaper-1.54"
Comment1 "https://www.waveshare.com/wiki/ESP32-C6-ePaper-1.54"
$EndDescr
$Comp
L MCU:ESP32-C6-Rescue ESP32-C6:ESP32-C6
U 1 1 60000000
P 4000 3000
F 0 "ESP32-C6" H 4000 4000 50 0000 L CNN
F 1 "ESP32-C6" H 4000 3000 50 0000 L CNN
$EndComp
$Comp
L Connector:USB-C-PWR Pad_USB-C
U 1 1 60000001
P 2000 2000
F 0 "USB-C" H 2000 1000 50 0000 L CNN
$EndComp
$Comp
L Sensor:Audio:INMP441 U_INMP441
U 1 1 60000002
P 6000 2000
F 0 "INMP441" H 6000 1500 50 0000 L CNN
F 1 "INMP441" H 6000 2000 50 0000 L CNN
$EndComp
$Comp
L Audio:Amplifier:MAX98357A U_MAX98357A
U 1 1 60000003
P 6000 3500
F 0 "MAX98357A" H 6000 3000 50 0000 L CNN
F 1 "MAX98357A" H 6000 3500 50 0000 L CNN
$EndComp
$Comp
L Switch:Tactile_SW SW1
U 1 1 60000004
P 6000 4500
F 0 "SW1" H 6000 5500 50 0000 L CNN
$EndComp
$Comp
L Switch:Tactile_SW SW2
U 1 1 60000005
P 6000 5000
F 0 "SW2" H 6000 6000 50 0000 L CNN
$EndComp
Wire Wire Line
	2000 2000 2500 2000
$EndSCHEMATC
# ESP32-C6 Pin Assignments
# I2C: GPIO18(SDA), GPIO8(SCL) - TCA9554, PCF85063 RTC
# SPI2 (e-paper): GPIO5(MOSI), GPIO4(MISO), GPIO6(CLK), GPIO7(CS), GPIO15(DC), GPIO11(RST), GPIO10(BUSY)
# I2S: GPIO19(MCLK), GPIO21(BCLK), GPIO22(WS), GPIO20(DIN), GPIO23(DOUT)
# SD: GPIO3(CS) - shared SPI bus
# Buttons: GPIO9(boot), GPIO2(pwr)